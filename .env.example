# ── REQUIRED ───────────────────────────────────────────────────────────────

# Your WhatsApp number in full international format (no + or spaces)
PHONE_NUMBER=256774411462

# Owner number — who can use owner-only commands (defaults to PHONE_NUMBER)
OWNER_NUMBER=256774411462

# ── SESSION (for Heroku / Railway / any hosting panel) ──────────────────────
# Get your SESSION_ID from the built-in pairing page:
#
#   1. Deploy the bot WITHOUT SESSION_ID set
#   2. Open  https://YOUR-APP-URL/pair  in a browser
#   3. Enter your WhatsApp number and enter the code in WhatsApp
#   4. Copy the SESSION_ID shown on the page
#   5. Set it here (or in your hosting panel env vars) and restart
#
# When SESSION_ID is set the bot connects immediately without pairing.
SESSION_ID=

# ── OPTIONAL ────────────────────────────────────────────────────────────────
# Keep-alive server port (hosting panels usually set PORT automatically)
PORT=3000
