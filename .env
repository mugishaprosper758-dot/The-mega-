# ╔══════════════════════════════════════════════════════════╗
# ║         PROSPER MD BOT — Configuration File           ║
# ║  Compatible with Replit, Katabump, and any Node panel   ║
# ╚══════════════════════════════════════════════════════════╝

# ── Bot Phone Number ──────────────────────────────────────────
# Your WhatsApp number WITHOUT + or spaces  (international format)
# Examples: 256774411462 (UG), 254712345678 (KE), 2348012345678 (NG)
PHONE_NUMBER=256767469728

# ── Owner / Admin Number ──────────────────────────────────────
# Number that receives owner-only privileges (antidelete, alerts, etc.)
# Defaults to PHONE_NUMBER if left blank
OWNER_NUMBER=256774411462

# ── Session ID ───────────────────────────────────────────────
# Paste your session string here so the bot reconnects without pairing.
#
# How to get it (choose ONE method):
#   A) Visit https://adevos-x-pair.onrender.com
#      Enter your number → pair with WhatsApp → copy the full SESSION_ID string
#
#   B) On Katabump / any panel: set SESSION_ID in the panel's env tab
#      (same string — the bot reads it from the environment automatically)
#
#   C) Place creds.json directly in the session/ folder (highest priority)
#
# Accepted formats — all of these work:
#   Plain base64:           eyJub2lzZUtl...
#   Prefixed (PROSPER): PROSPER;eyJub2lzZUtltl...
#   ADEVOS-X format:        ADEVOS-X:~eyJub2lzZUtl...
#   Data URI:               data:application/json;base64,eyJub2...
#   Raw JSON:               {"noiseKey":...}
#
# Leave blank to pair fresh with a pairing code on next start.
SESSION_ID=

# ── Bot Mode ──────────────────────────────────────────────────
# public  = anyone can use the bot
# private = only owner can use the bot
BOT_MODE=public

# ── Web Server Port ───────────────────────────────────────────
# Replit sets PORT automatically. Katabump and most panels do too.
# Only change this if your panel requires a specific port.
PORT=3000
